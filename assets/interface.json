{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaL",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/leishang2216/MaL",
    "version": "0.0.1",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Visual Studio",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        // child_args 相对路径以 interface.json 所在目录为基准
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "自动刷向阳花",
            "entry": "Sunflower_LoopEntry",
            "option": [
                "向阳花等待模式",
                "向阳花是否为鞠躬号"
            ]
        }
    ],
    "option": {
        "向阳花等待模式": {
            "type": "select",
            "label": "等待模式",
            "description": "可选择固定秒数等待，或按输入区间随机等待后再开始下一轮阶段1。",
            "default_case": "固定秒数",
            "cases": [
                {
                    "name": "固定秒数",
                    "option": [
                        "向阳花固定等待"
                    ]
                },
                {
                    "name": "随机区间",
                    "option": [
                        "向阳花随机等待"
                    ]
                }
            ]
        },
        "向阳花固定等待": {
            "type": "input",
            "label": "固定等待秒数",
            "description": "等待节点会在进入下一轮阶段1前固定等待指定秒数。",
            "inputs": [
                {
                    "name": "固定等待秒数",
                    "label": "固定等待秒数",
                    "default": "10",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入不小于 0 的整数秒数"
                }
            ],
            "pipeline_override": {
                "Sunflower_WaitBySetting": {
                    "custom_action_param": {
                        "mode": "fixed",
                        "fixed_seconds": "{固定等待秒数}",
                        "random_min_seconds": 0,
                        "random_max_seconds": 0
                    }
                }
            }
        },
        "向阳花随机等待": {
            "type": "input",
            "label": "随机等待区间秒数",
            "description": "等待节点会在起始和终止秒数之间随机取一个整数秒数，再开始下一轮阶段1。",
            "inputs": [
                {
                    "name": "随机起始秒数",
                    "label": "随机起始秒数",
                    "default": "10",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入不小于 0 的整数秒数"
                },
                {
                    "name": "随机终止秒数",
                    "label": "随机终止秒数",
                    "default": "20",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入不小于 0 的整数秒数"
                }
            ],
            "pipeline_override": {
                "Sunflower_WaitBySetting": {
                    "custom_action_param": {
                        "mode": "random",
                        "fixed_seconds": 0,
                        "random_min_seconds": "{随机起始秒数}",
                        "random_max_seconds": "{随机终止秒数}"
                    }
                }
            }
        },
        "向阳花是否为鞠躬号": {
            "type": "switch",
            "label": "是否为鞠躬号",
            "description": "为 Yes 时进入阶段2页面判断；为 No 时先等待，再重新开始阶段1。",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Sunflower_BowAccountGate": {
                            "next": "Sunflower_Stage2_Entry"
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Sunflower_BowAccountGate": {
                            "next": "Sunflower_WaitBySetting"
                        }
                    }
                }
            ]
        }
    }
}
